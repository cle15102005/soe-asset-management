# ============================================================
# SOE Asset Management — Root .gitignore
# Covers: root, backend/ (Spring Boot), frontend/ (React/Vite)
# ============================================================

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / Editor ─────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
*.iws
*.iml
*.ipr
*.swp
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ── Backend — Spring Boot / Java / Maven ─────────────────────
backend/target/
backend/build/
backend/.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/
backend/HELP.md

# ── Backend — Sensitive config (never commit these) ──────────
backend/src/main/resources/application.yml
backend/src/main/resources/application.yaml
backend/src/main/resources/application-dev.yml
backend/src/main/resources/application-dev.yaml

# ── Frontend — Node / Vite / React ───────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# ── Frontend — Logs ──────────────────────────────────────────
frontend/logs/
frontend/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── NetBeans ─────────────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ── Docker / Environment secrets ─────────────────────────────
.env
.env.local
.env.production
# Keep the example template
!.env.example
!frontend/.env.example

#AI configs
CLAUDE.md
.claudeignore


